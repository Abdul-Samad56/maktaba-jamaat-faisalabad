{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://maktaba-jamaat-faisalabad.onrender.com/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "https://maktaba-jamaat-faisalabad.onrender.com/images/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://maktaba-jamaat-faisalabad.onrender.com/sitemap.xml"
    },
    {
      "source": "/product/:id",
      "destination": "https://maktaba-jamaat-faisalabad.onrender.com/ssr/product/:id"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
